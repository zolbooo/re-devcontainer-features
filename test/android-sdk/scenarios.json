{
    "specific_sdk": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "android-sdk": {
                "platform": "32",
                "extra_packages": "ndk;25.2.9519653 sources;android-32"
            }
        }
    },
    "wanted_emulators": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "android-sdk": {
                "wanted_emulators": "medium_phone"
            }
        }
    },
    "preexisting_android_cli": {
        "build": {
            "dockerfile": "Dockerfile",
            "context": "."
        },
        "features": {
            "android-sdk": {}
        }
    }
}
