            "description": "Ghidra release version"
        }
    },
    "dependsOn": {
        "ghcr.io/devcontainers/features/java:1": {
            "version": "21"
        }
    },
    "installsAfter": ["ghcr.io/devcontainers/features/common-utils"]
}
