{
    "name": "Android SDK",
    "id": "android-sdk",
    "version": "2.0.2",
    "description": "Install Android SDK packages and emulators using Google's Android CLI.",
    "containerEnv": {
        "ANDROID_HOME": "/usr/local/lib/android",
        "ANDROID_SDK_ROOT": "$ANDROID_HOME",
        "ANDROID_AVD_HOME": "$HOME/.android/avd",
        "PATH": "$PATH:$ANDROID_HOME/platform-tools:$ANDROID_HOME/emulator:/usr/local/lib/android-build-tools"
    },
    "options": {
        "platform": {
            "type": "string",
            "default": "34",
            "description": "SDK platform version"
        },
        "build_tools": {
            "type": "string",
            "default": "34.0.0",
            "description": "SDK build-tools version"
        },
        "base_packages": {
            "type": "string",
            "default": "",
            "description": "packages will override default packages, split by space"
        },
        "extra_packages": {
            "type": "string",
            "default": "",
            "description": "extra packages, split by space"
        },
        "wanted_emulators": {
            "type": "string",
            "default": "",
            "description": "space-separated Android CLI emulator profiles such as 'medium_phone small_phone'"
        }
    },
    "installsAfter": ["ghcr.io/devcontainers/features/common-utils", "ghcr.io/akhildevelops/devcontainer-features/apt"]
}
